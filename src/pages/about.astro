---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactCard from '../components/ContactCard.astro';
import SkillCard from '../components/SkillCard.astro';
import '../styles/globals.css';

const title = 'About | Nandika Soi';
const description = 'About me page for a cybersecurity and AI-focused portfolio.';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link href="https://api.fontshare.com/v2/css?f[]=switzer@400&f[]=khand@700&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <Header current="/about" />
    <main class="mx-auto flex max-w-6xl flex-col gap-16 px-6 py-16 sm:px-8 lg:px-10 lg:py-24">
      <section class="space-y-6">
        <p class="text-sm uppercase tracking-[0.3em] text-accent">About Me</p>
        <h1 class="max-w-3xl text-4xl sm:text-5xl lg:text-6xl">Nandika Soi</h1>
        <p class="max-w-3xl text-lg leading-8 text-black/75">I am a first-year Computer Engineering student at Thapar Institute of Engineering & Technology, passionate about cybersecurity, AI, and building practical software projects. I enjoy learning Linux, networking, ethical hacking, SOC operations, and threat intelligence while participating in hackathons and continuously improving my technical skills.</p>
        <p class="max-w-3xl text-lg leading-8 text-black/75">My goal is to become a cybersecurity engineer and create impactful technology that helps teams stay more secure and effective in a rapidly evolving threat landscape.</p>
      </section>

      <section class="grid gap-8 border-t border-black/10 pt-10 lg:grid-cols-2">
        <SkillCard title="Programming" items={[ 'C', 'Python' ]} />
        <SkillCard title="Cybersecurity" items={[ 'Linux', 'Networking', 'SOC Basics', 'Threat Intelligence', 'Ethical Hacking (Learning)' ]} />
        <SkillCard title="Web Development" items={[ 'HTML', 'CSS', 'JavaScript', 'Astro', 'Tailwind CSS' ]} />
        <SkillCard title="Tools & Learning" items={[ 'Git', 'GitHub', 'VS Code', 'VMware', 'Cloudflare Pages', 'AI', 'Machine Learning', 'CTFs' ]} />
      </section>

      <section class="border-t border-black/10 pt-10">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
          <div class="max-w-xl">
            <p class="text-sm uppercase tracking-[0.3em] text-accent">Timeline</p>
            <h2 class="mt-4 text-3xl sm:text-4xl">A clear path forward</h2>
          </div>
          <div class="space-y-6">
            <div class="rounded-[2rem] border border-black/10 bg-white p-6 shadow-[4px_4px_0_0_rgba(0,0,0,0.08)]">
              <p class="text-sm uppercase tracking-[0.2em] text-black/60">2025</p>
              <p class="mt-3 text-lg font-semibold text-black">Started Computer Engineering at TIET.</p>
            </div>
            <div class="rounded-[2rem] border border-black/10 bg-white p-6 shadow-[4px_4px_0_0_rgba(0,0,0,0.08)]">
              <p class="text-sm uppercase tracking-[0.2em] text-black/60">2025</p>
              <p class="mt-3 text-lg font-semibold text-black">Began learning Linux and Cybersecurity.</p>
            </div>
            <div class="rounded-[2rem] border border-black/10 bg-white p-6 shadow-[4px_4px_0_0_rgba(0,0,0,0.08)]">
              <p class="text-sm uppercase tracking-[0.2em] text-black/60">2026</p>
              <p class="mt-3 text-lg font-semibold text-black">Working on portfolio and personal projects.</p>
            </div>
            <div class="rounded-[2rem] border border-black/10 bg-white p-6 shadow-[4px_4px_0_0_rgba(0,0,0,0.08)]">
              <p class="text-sm uppercase tracking-[0.2em] text-black/60">Future</p>
              <p class="mt-3 text-lg font-semibold text-black">Cybersecurity Engineer.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="contact" class="border-t border-black/10 pt-10">
        <div class="space-y-6">
          <p class="text-sm uppercase tracking-[0.3em] text-accent">Contact</p>
          <h2 class="text-3xl sm:text-4xl">Let’s connect and collaborate</h2>
          <p class="max-w-2xl text-lg leading-8 text-black/75">If you’d like to discuss cybersecurity, AI projects, or opportunities to build something meaningful, I’d love to hear from you.</p>
        </div>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <ContactCard href="mailto:your-email@example.com" label="Email" subtitle="your-email@example.com" icon="📧" />
          <ContactCard href="https://github.com/placeholder" label="GitHub" subtitle="github.com/nandika" icon="💻" />
          <ContactCard href="https://linkedin.com/in/placeholder" label="LinkedIn" subtitle="linkedin.com/in/nandika" icon="🔗" />
          <ContactCard href="https://instagram.com/placeholder" label="Instagram" subtitle="@nandikay" icon="📷" />
        </div>
        <div class="mt-8">
          <a href="mailto:your-email@example.com" class="inline-flex items-center justify-center rounded-full bg-accent px-8 py-4 text-sm font-semibold uppercase tracking-[0.15em] text-white transition hover:opacity-90">Send Email</a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
