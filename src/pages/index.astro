---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';

const title = 'Nandika Soi | Portfolio';
const description = 'Placeholder portfolio site for Nandika Soi with project highlights.';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link href="https://api.fontshare.com/v2/css?f[]=switzer@400&f[]=khand@700&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <Header current="/" />
    <main class="mx-auto flex max-w-6xl flex-col gap-16 px-6 py-16 sm:px-8 lg:px-10 lg:py-24">
      <section class="grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="space-y-6">
          <p class="text-sm uppercase tracking-[0.3em] text-accent">Placeholder introduction</p>
          <h1 class="max-w-3xl text-5xl leading-none sm:text-6xl lg:text-7xl">NANDIKA SOI • BUILDING WITH CLARITY</h1>
          <p class="max-w-2xl text-lg leading-8 text-black/75">This is placeholder content for Pete’s portfolio site. Replace this copy with a bold introduction, current focus, and a short personal statement.</p>
        </div>
        <div class="border border-black/15 bg-black p-8 text-white">
          <p class="mb-4 text-sm uppercase tracking-[0.3em] text-accent">Current focus</p>
          <h2 class="mb-4 text-3xl">Projects • ideas</h2>
          <p class="text-base leading-7 text-white/80">Placeholder block for upcoming work, current experiments, or a short callout about Nandika’s mission.</p>
        </div>
      </section>

      <section class="grid gap-8 border-t border-black/10 pt-10 lg:grid-cols-[1fr_0.7fr]">
        <div class="space-y-4">
          <p class="text-sm uppercase tracking-[0.3em] text-accent">About the work</p>
          <h2 class="text-3xl sm:text-4xl">A concise, modern profile with room to grow.</h2>
          <p class="max-w-2xl text-lg leading-8 text-black/75">This section can later explain background, values, or notable achievements. For now it remains intentionally simple and easy to replace.</p>
        </div>
        <div class="flex flex-col justify-center gap-4">
          <a href="/projects" class="inline-flex items-center justify-center bg-accent px-6 py-3 text-center font-semibold uppercase tracking-[0.15em] text-white transition hover:opacity-90">View Projects</a>
          <a href="/about" class="inline-flex items-center justify-center border border-black px-6 py-3 text-center font-semibold uppercase tracking-[0.15em] transition hover:bg-black hover:text-white">Read About</a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
