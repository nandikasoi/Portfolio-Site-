---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactCard from '../components/ContactCard.astro';
import '../styles/globals.css';

const title = 'Nandika Soi | Portfolio';
const description = 'Modern portfolio focused on cybersecurity, AI, and software development.';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link href="https://api.fontshare.com/v2/css?f[]=switzer@400&f[]=khand@700&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <Header current="/" />
    <main class="mx-auto flex max-w-6xl flex-col gap-16 px-6 py-16 sm:px-8 lg:px-10 lg:py-24">
      <section class="grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="space-y-6">
          <p class="text-sm uppercase tracking-[0.3em] text-accent">Placeholder introduction</p>
          <h1 class="max-w-3xl text-5xl leading-none sm:text-6xl lg:text-7xl">NANDIKA SOI • BUILDING WITH CLARITY</h1>
          <p class="max-w-2xl text-lg leading-8 text-black/75">This is placeholder content for Pete’s portfolio site. Replace this copy with a bold introduction, current focus, and a short personal statement.</p>
        </div>
        <div class="border border-black/15 bg-black p-8 text-white">
          <p class="mb-4 text-sm uppercase tracking-[0.3em] text-accent">Current focus</p>
          <h2 class="mb-4 text-3xl">Projects • ideas</h2>
          <p class="text-base leading-7 text-white/80">Placeholder block for upcoming work, current experiments, or a short callout about Nandika’s mission.</p>
        </div>
      </section>

      <section class="grid gap-8 border-t border-black/10 pt-10 lg:grid-cols-[1fr_0.9fr]">
        <div class="space-y-4">
          <p class="text-sm uppercase tracking-[0.3em] text-accent">Let’s Connect</p>
          <h2 class="text-3xl sm:text-4xl">Let’s Build Something Together</h2>
          <p class="max-w-2xl text-lg leading-8 text-black/75">I’m always excited to connect with people interested in cybersecurity, AI, open-source projects, hackathons, and technology. Whether you have an idea, a collaboration, or just want to say hello, feel free to reach out.</p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <ContactCard href="mailto:your-email@example.com" label="Email" subtitle="your-email@example.com" icon="📧" />
          <ContactCard href="https://github.com/placeholder" label="GitHub" subtitle="github.com/nandika" icon="💻" />
          <ContactCard href="https://linkedin.com/in/placeholder" label="LinkedIn" subtitle="linkedin.com/in/nandika" icon="🔗" />
          <ContactCard href="https://instagram.com/placeholder" label="Instagram" subtitle="@nandikay" icon="📷" />
        </div>
      </section>

      <section class="flex flex-col items-start gap-4 border-t border-black/10 pt-10">
        <a href="/about#contact" class="inline-flex items-center justify-center rounded-full bg-accent px-8 py-4 text-sm font-semibold uppercase tracking-[0.15em] text-white transition hover:opacity-90">Contact Me</a>
      </section>
    </main>
    <Footer />
  </body>
</html>
