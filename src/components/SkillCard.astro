---
const { title, items } = Astro.props;
---
<div class="rounded-[2rem] border border-black/10 bg-white p-6 shadow-[4px_4px_0_0_rgba(0,0,0,0.08)] transition duration-300 hover:-translate-y-1">
  <h3 class="mb-4 text-2xl font-semibold tracking-[0.03em] text-black">{title}</h3>
  <ul class="space-y-2 text-black/75">
    {items.map((item) => (
      <li class="inline-flex items-center gap-2 text-sm">• {item}</li>
    ))}
  </ul>
</div>
