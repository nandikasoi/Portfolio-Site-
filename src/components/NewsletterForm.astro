<form class="flex flex-col gap-3 rounded-none border border-black bg-white p-6 shadow-[6px_6px_0_0_#000000] sm:flex-row sm:items-center">
  <label class="sr-only" for="email">Email address</label>
  <input
    id="email"
    name="email"
    type="email"
    placeholder="Enter your email"
    class="w-full border border-black px-4 py-3 text-base outline-none transition focus:border-accent"
    required
  />
  <button
    type="submit"
    class="inline-flex items-center justify-center bg-accent px-5 py-3 font-semibold uppercase tracking-[0.15em] text-white transition hover:opacity-90"
  >
    Join Newsletter
  </button>
</form>
