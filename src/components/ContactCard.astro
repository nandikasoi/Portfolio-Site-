---
const { href = '#', label, icon, subtitle } = Astro.props;
---
<a
  href={href}
  class="group block rounded-3xl border border-black/10 bg-white p-6 text-left transition duration-300 hover:-translate-y-1 hover:border-accent hover:bg-black/5 focus:outline-none focus:ring-2 focus:ring-accent/30"
>
  <div class="flex items-start gap-4">
    <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-black/5 text-2xl transition duration-300 group-hover:bg-accent group-hover:text-white">
      {icon}
    </span>
    <div>
      <p class="text-sm uppercase tracking-[0.25em] text-black/50">{label}</p>
      <p class="mt-3 text-base font-semibold text-black">{subtitle}</p>
    </div>
  </div>
</a>
