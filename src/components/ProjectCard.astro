---
const { title, description, tech = [], github = '#', demo } = Astro.props;
---

<article class="group overflow-hidden rounded-[2rem] border border-black/10 bg-white p-6 shadow-[4px_4px_0_0_rgba(0,0,0,0.08)] transition duration-300 hover:-translate-y-1 hover:border-accent">
  <div class="mb-4 flex items-start justify-between gap-4">
    <p class="text-sm uppercase tracking-[0.2em] text-accent">Project</p>
    <span class="rounded-full border border-black/10 px-3 py-1 text-xs uppercase tracking-[0.18em] text-black/60 transition duration-300 group-hover:bg-accent group-hover:text-white">Featured</span>
  </div>
  <h3 class="mb-4 text-2xl font-semibold tracking-[0.02em] text-black">{title}</h3>
  <p class="mb-6 text-base leading-7 text-black/75">{description}</p>
  <div class="mb-6 flex flex-wrap gap-2">
    {tech.map((item) => (
      <span class="rounded-full border border-black/10 bg-black/5 px-3 py-1 text-sm text-black/70">{item}</span>
    ))}
  </div>
  <div class="mt-auto flex flex-wrap gap-3">
    <a
      href={github}
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center justify-center rounded-full border border-black/10 bg-black/5 px-5 py-3 text-sm font-semibold uppercase tracking-[0.15em] text-black transition duration-300 hover:border-accent hover:bg-accent hover:text-white"
    >
      GitHub
    </a>
    {demo && (
      <a
        href={demo}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white px-5 py-3 text-sm font-semibold uppercase tracking-[0.15em] text-black transition duration-300 hover:border-accent hover:bg-black/5"
      >
        Live Demo
      </a>
    )}
  </div>
</article>
