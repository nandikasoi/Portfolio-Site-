---
const { title, description, href = '#' } = Astro.props;
---

<article class="border border-black/15 bg-white p-6 shadow-[4px_4px_0_0_rgba(0,0,0,0.08)]">
  <p class="mb-3 text-sm uppercase tracking-[0.2em] text-accent">Placeholder Project</p>
  <h3 class="mb-3 text-2xl">{title}</h3>
  <p class="mb-5 text-base leading-7 text-black/75">{description}</p>
  <a href={href} class="font-semibold uppercase tracking-[0.15em] text-accent hover:underline">View preview →</a>
</article>
